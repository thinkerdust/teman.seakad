            "cover": "images/background/cover-bg.png",
            "paper": "images/background/paper-texture.png",
            "watercolor": "images/background/watercolor-bg.png",
            "gallery": "images/background/gallery-bg.png"
        },
        "floral": {
            "corner_left": "images/floral/flower-corner-top-left.png",
            "corner_right": "images/floral/flower-corner-top-right.png",
            "corner_bottom": "images/floral/flower-corner-bottom-right.png",
            "rose_01": "images/floral/rose-01.png",
            "rose_02": "images/floral/rose-02.png",
            "leaf_01": "images/floral/leaf-01.png",
            "leaf_02": "images/floral/leaf-02.png",
