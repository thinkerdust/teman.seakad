{
    "name": "Floral Elegant",
    "version": "2.0",
    "author": "Teman Seakad",
    "identity": {
        "style": "romantic",
        "mood": [
            "soft",
            "warm",
            "beautiful",
            "luxury",
            "cinematic"
        ],
        "description": "A luxury floral wedding invitation card brought to life digitally"
    },
    "design": {
        "colors": {
            "primary": "#b86b70",
            "secondary": "#ebdcd7",
            "accent": "#D4AF37",
            "background": "#faf6f0",
            "text": "#4e3e3b",
            "surface": "#ffffff"
        },
        "typography": {
