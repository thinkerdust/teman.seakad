            "ornaments/floral-corner.png"
        ],
        "background": {
            "texture": "backgrounds/soft.png"
        },
        "audio": {
            "enabled": true
        }
    },
    "layout": {
        "hero": "fullscreen"
    },
    "features": {
        "music": true,
        "gallery": true,
        "countdown": true,
        "rsvp": true,
        "stories": true,
        "gift": true
