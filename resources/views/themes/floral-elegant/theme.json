{
    "name": "Floral Elegant",
    "version": "1.0",
    "author": "Teman Seakad",
    "identity": {
        "style": "romantic",
        "mood": [
            "soft",
            "warm",
            "beautiful"
        ],
        "description": "Soft and romantic floral wedding experience"
    },
    "design": {
        "colors": {
            "primary": "#b86b70",
            "secondary": "#ebdcd7",
            "accent": "#8fa89b",
            "background": "#faf6f0",
            "text": "#4e3e3b"
        },
        "typography": {
