{
    "name": "Islamic Wedding",
    "version": "1.0",
    "author": "Teman Seakad",
    "identity": {
        "style": "traditional",
        "mood": [
            "spiritual",
            "calm",
            "elegant",
            "green"
        ],
        "description": "Spiritual and elegant islamic wedding experience"
    },
    "design": {
        "colors": {
            "primary": "#107c41",
            "secondary": "#ebf5ee",
